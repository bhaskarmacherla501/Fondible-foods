# ──────────────────────────────────────────────
# FONDIBLE PLATFORM — Environment Variables
# Copy to .env.local and fill all values
# ──────────────────────────────────────────────

# App
NEXT_PUBLIC_APP_URL=http://localhost:3007
NEXT_PUBLIC_APP_NAME=Fondible
NODE_ENV=development
PORT=3007

# Database (PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/fondible_db?schema=public"

# NextAuth
NEXTAUTH_URL=http://localhost:3007
NEXTAUTH_SECRET=your-super-secret-key-min-32-chars

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Razorpay
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your_key_id

# WhatsApp (Twilio or Meta Cloud API)
WHATSAPP_PHONE_NUMBER=918019730055
WHATSAPP_API_TOKEN=your-whatsapp-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# Email (Nodemailer / SendGrid / Resend)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-email-password
EMAIL_FROM=noreply@fondible.in

# SMS / OTP (MSG91 or Twilio)
MSG91_AUTH_KEY=your-msg91-key
MSG91_SENDER_ID=FONDBL
MSG91_TEMPLATE_ID=your-template-id

# Logistics
SHIPROCKET_EMAIL=your@email.com
SHIPROCKET_PASSWORD=your-shiprocket-password
DELHIVERY_TOKEN=your-delhivery-token

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your-google-maps-api-key

# Cloudinary (Image CDN)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name

# Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Admin
ADMIN_SECRET_KEY=your-admin-setup-key
